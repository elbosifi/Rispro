# =============================================================================
# RISpro Reception - Environment Configuration Template
# =============================================================================
# For first-time setup, run: ./scripts/setup-docker.sh
# It will generate a .env file with secure random credentials.
#
# This file is a reference template only. Do not copy it manually.
# =============================================================================

# -- Node.js Environment --
NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# -- Database Mode Marker (written by setup-docker.sh) --
# Set by the setup script. Determines which compose files to use.
#   internal  = use docker-compose.yml + docker-compose.internal-db.yml
#   external  = use docker-compose.yml only
# RISPRO_DB_MODE=internal

# -- Database Connection --
#
# INTERNAL DATABASE (managed by Docker):
#   DATABASE_URL=postgresql://rispro:QOYR0s1h%2FuI7wqZrzW0gjNfQY61VwA6ek0wXsUEx6So%3D@postgres:5432/rispro
#   DB_USER=rispro
#   DB_PASSWORD=QOYR0s1h/uI7wqZrzW0gjNfQY61VwA6ek0wXsUEx6So=
#   DB_NAME=rispro
#
# EXTERNAL DATABASE (your own PostgreSQL server):
#   DATABASE_URL=postgresql://user:encoded-password@your-db-host:5432/rispro
#
# Note: Special characters in password must be URL-encoded.
#   @ = %40  : = %3A  / = %2F  # = %23  ? = %3F
#   & = %26  = = %3D  + = %2B  space = %20
DATABASE_URL=postgresql://rispro:QOYR0s1h%2FuI7wqZrzW0gjNfQY61VwA6ek0wXsUEx6So%3D@postgres:5432/rispro

# Optional: Internal database credentials (only used with docker-compose.internal-db.yml)
# DB_USER=rispro
# DB_PASSWORD=QOYR0s1h/uI7wqZrzW0gjNfQY61VwA6ek0wXsUEx6So=
# DB_NAME=rispro

# -- Database SSL --
# Internal Docker PostgreSQL: must be false.
# Internal Docker PostgreSQL also uses DATABASE_SSL_REJECT_UNAUTHORIZED=false.
# External PostgreSQL: set true only if your server supports SSL.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: Fine-tune database connection
# DB_POOL_MAX=10

# -- Authentication --
# MUST be a long random string (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# -- Session Configuration --
COOKIE_NAME=rispro_session
# Set to true if behind HTTPS reverse proxy
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
SESSION_HOURS=8

# -- Supervisor Re-authentication --
SUPERVISOR_REAUTH_MINUTES=10

# -- File Uploads --
REQUEST_BODY_LIMIT=8mb
UPLOADS_DIR=storage/uploads

# -- DICOM Gateway (Embedded, MWL only) --
# The embedded DICOM gateway starts automatically in Docker.
# RISpro bundles a source-built DCMTK toolchain with wlmscpfs for MWL.

# -- Initial Supervisor Account (used only for first-time seeding) --
SEED_SUPERVISOR_USERNAME=admin
SEED_SUPERVISOR_PASSWORD=admin
SEED_SUPERVISOR_FULL_NAME=System Administrator
