# =============================================================================
# RISpro Reception - Environment Configuration Template
# =============================================================================
# DO NOT EDIT THIS FILE DIRECTLY FOR FIRST-TIME SETUP.
#
# For first-time setup, run: ./scripts/setup-docker.sh
# It will generate a .env file with secure random credentials.
#
# For updates after initial setup, edit your existing .env file.
# =============================================================================

# -- Node.js Environment --
NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# -- Database Connection --
#
# INTERNAL DATABASE (default, managed by Docker):
#   DATABASE_URL=postgresql://rispro:rispro_password@postgres:5432/rispro
#   Use with: docker compose -f docker-compose.yml -f docker-compose.internal-db.yml up -d --build
#
# EXTERNAL DATABASE (your own PostgreSQL server):
#   DATABASE_URL=postgresql://user:password@your-db-host:5432/rispro
#   Use with: docker compose up -d --build
#
# Note: Special characters in password must be URL-encoded (e.g., @ -> %40)
DATABASE_URL=postgresql://rispro:rispro_password@postgres:5432/rispro

# Optional: Internal database credentials (only used with docker-compose.internal-db.yml)
DB_USER=rispro
DB_PASSWORD=rispro_password
DB_NAME=rispro

# Optional: Fine-tune database connection
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DB_POOL_MAX=10

# -- Authentication --
# MUST be a long random string (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# -- Session Configuration --
COOKIE_NAME=rispro_session
# Set to true if behind HTTPS reverse proxy
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
SESSION_HOURS=8

# -- Supervisor Re-authentication --
SUPERVISOR_REAUTH_MINUTES=10

# -- File Uploads --
REQUEST_BODY_LIMIT=8mb
UPLOADS_DIR=storage/uploads

# -- DICOM Gateway (Embedded) --
# The embedded DICOM gateway starts automatically in Docker.
# All required DCMTK tools (wlmscpfs, ppsscpfs, dump2dcm, dcmdump) are built into the image.
#
# To disable the embedded gateway (use external sidecar instead):
# RISPRO_DISABLE_EMBEDDED_DICOM_GATEWAY=1
#
# Default DICOM settings (can be changed via Settings UI):
# DICOM_BIND_HOST=0.0.0.0
# DICOM_MWL_AE_TITLE=RISPRO_MWL
# DICOM_MWL_PORT=11112
# DICOM_MPPS_AE_TITLE=RISPRO_MPPS
# DICOM_MPPS_PORT=11113
#
# Worklist directories are auto-created and persisted to Docker volume.

# -- Initial Supervisor Account (used only for first-time seeding) --
SEED_SUPERVISOR_USERNAME=admin
SEED_SUPERVISOR_PASSWORD=ChangeThisStrongPassword123!
SEED_SUPERVISOR_FULL_NAME=System Administrator
