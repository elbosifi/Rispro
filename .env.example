NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rispro
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_NAME=rispro_session
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_HOURS=8
REQUEST_BODY_LIMIT=1mb
TRUST_PROXY=1
SEED_SUPERVISOR_USERNAME=admin
SEED_SUPERVISOR_PASSWORD=replace-with-a-strong-password
SEED_SUPERVISOR_FULL_NAME=Supervisor
