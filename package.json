{
  "name": "rispro-reception",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed:supervisor": "tsx src/db/seed-supervisor.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "build:frontend": "cd frontend && npm run build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "check": "rg --files -g '*.ts' -g '*.mts' -0 | xargs -0 -I{} npx tsc --noEmit \"{}\"",
    "gateway:build-worklists": "node scripts/dicom-gateway/build-worklists.mjs",
    "gateway:rebuild-sources": "tsx scripts/dicom-gateway/rebuild-worklist-sources.mjs",
    "gateway:reconcile-orthanc-mwl": "tsx scripts/dicom-gateway/reconcile-orthanc-mwl.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dicom-dimse-native": "^2.6.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mdb-reader": "^3.2.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
